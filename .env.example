# ── YouTube API ──────────────────────────────────────────────────────────────
# YouTube Data API v3 key (required).
# Get one at https://console.cloud.google.com/
YOUTUBE_API_KEY=AIzaSyDMaR8zfNunhkRb8w38MOBLAzSUKCmTrm8

# ── Channel source ───────────────────────────────────────────────────────────
# Excel file that lists channel IDs / handles to collect.
CHANNELS_FILE=channels.xlsx

# ── Collection limits ────────────────────────────────────────────────────────
# Set to 0 to collect everything (default).  Positive integer = hard cap.
MAX_VIDEOS=0
MAX_COMMENTS_PER_VIDEO=0

# ── Output ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=output

# ── Analysis settings ────────────────────────────────────────────────────────
ANALYSIS_BATCH_SIZE=32

# ── English analysis models ──────────────────────────────────────────────────
# Any HuggingFace text-classification model ID can be used here.
# Models are downloaded automatically on first run.

# Binary sentiment (POSITIVE / NEGATIVE)
ENGLISH_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# 7-class emotion (anger / disgust / fear / joy / neutral / sadness / surprise)
ENGLISH_EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base

# ── Chinese analysis models ───────────────────────────────────────────────────
# Models must support Chinese (Simplified / Traditional) text.
# Models are downloaded automatically on first run.

# 3-class sentiment (positive / neutral / negative) — multilingual
CHINESE_SENTIMENT_MODEL=lxyuan/distilbert-base-multilingual-cased-sentiments-student

# 6-class emotion (anger / fear / joy / love / sadness / surprise) — multilingual
CHINESE_EMOTION_MODEL=michellejieli/emotion_text_classifier
